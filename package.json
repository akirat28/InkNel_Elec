{
  "name": "inknel-elec",
  "productName": "InkNel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Markdown memo app for desktop (Electron) with future cloud sync",
  "main": "out/main/index.js",
  "scripts": {
    "postinstall": "node scripts/patch-electron-name.cjs && electron-rebuild -f -w better-sqlite3",
    "predev": "node scripts/patch-electron-name.cjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "electron": "^32.1.2",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/state": "^6.4.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.34.1",
    "better-sqlite3": "^11.3.0",
    "codemirror": "^6.0.1",
    "markdown-it": "^14.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
